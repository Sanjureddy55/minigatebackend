# =============================================================================
# MiniGate — Environment Variables Template
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================================

# =============================================================================
# Django Core
# Generate a new key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# =============================================================================
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# PostgreSQL Database
# The engine is fixed to PostgreSQL in settings — only credentials go here.
# =============================================================================
POSTGRES_DB=minigatedb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Surya*13
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Set to DEBUG to print every SQL query to the console (dev profiling only)
DB_LOG_LEVEL=WARNING

# =============================================================================
# CORS — comma-separated list of allowed frontend origins
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Redis / Celery
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Email
# For development: use console backend (prints to terminal, sends nothing)
# For production:  switch to SMTP and fill in host credentials
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
